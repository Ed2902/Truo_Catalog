APP_NAME="catalog-api"
NODE_ENV="development"
PORT="3001"
API_PREFIX="api"
TRUST_PROXY="false"
APP_TIME_ZONE="America/Bogota"

CORS_ORIGINS="http://localhost:3000,http://localhost:5173"
CORS_CREDENTIALS="true"
CORS_METHODS="GET,HEAD,POST,PUT,PATCH,DELETE,OPTIONS"
CORS_ALLOWED_HEADERS="Authorization,Content-Type,X-Request-Id"
CORS_EXPOSED_HEADERS="X-Request-Id,X-Response-Time"

LOG_LEVEL="debug"
LOG_PRETTY_PRINT="true"

DATABASE_URL="postgresql://postgres:password@localhost:5432/truo_db?schema=catalog"
IDENTITY_BASE_URL="http://localhost:3000"
IDENTITY_INTERNAL_TOKEN=""
IDENTITY_SIGNALS_TIMEOUT_MS="3000"
STORAGE_S3_ENDPOINT="http://localhost:9000"
STORAGE_S3_ACCESS_KEY="admin"
STORAGE_S3_SECRET_KEY="admin123"
STORAGE_S3_BUCKET="catalog-images"
STORAGE_S3_FORCE_PATH_STYLE="true"
STORAGE_S3_PUBLIC_BASE_URL="http://localhost:9000"
STORAGE_MAX_UPLOAD_SIZE="5242880"
AUTH_ACCESS_TOKEN_SECRET="shared-access-secret-change-me"
AUTH_ACCESS_TOKEN_TTL="15m"
AUTH_REFRESH_TOKEN_SECRET="shared-refresh-secret-change-me"
AUTH_REFRESH_TOKEN_TTL="30d"

RATE_LIMIT_TTL="60000"
RATE_LIMIT_LIMIT="100"
SENSITIVE_RATE_LIMIT_TTL="60000"
SENSITIVE_RATE_LIMIT_LIMIT="120"
